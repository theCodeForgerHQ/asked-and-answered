# Slack app credentials (App A — internal/sandbox install)
SLACK_BOT_TOKEN=xoxb-...
SLACK_SIGNING_SECRET=...
# Optional: set to run in Socket Mode (local dev); omit for HTTP mode (deploy)
SLACK_APP_TOKEN=xapp-...

# Anthropic (drafting model)
ANTHROPIC_API_KEY=sk-ant-...
# Optional model override
# AA_MODEL=claude-haiku-4-5-20251001

# Storage
AA_DB_PATH=asked-and-answered.db
# Keyed content-hashing for the ledger (integrity; rotate = new chain)
AA_LEDGER_KEY=change-me

# HTTP port (deploy)
PORT=3000
